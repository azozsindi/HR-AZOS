rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - username: string
    //   - role: string ("superadmin", "company")
    //   - companyId: string (optional)
    //   - companyData: map (optional)
    //
    // Collection: companies
    // Document ID: companyId
    // Fields:
    //   - name: string
    //   - industry: string
    //   - primaryColor: string
    //   - employees: list of maps
    //   ... other company settings
    //
    // Collection: alerts
    // Document ID: randomId
    // Fields:
    //   - userId: string
    //   - name: string
    //   - expiryDate: string
    //   ... other alert fields
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (("email" in request.auth.token && request.auth.token.email.matches("(?i)azozsindi23@gmail.com")) || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'));
    }

    function isSameCompany(companyId) {
      return isAuthenticated() && (getUserData().companyId == companyId || isSuperAdmin());
    }

    // Rules
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /companies/{companyId} {
      allow read: if isSameCompany(companyId);
      allow write: if isSuperAdmin();
    }

    match /alerts/{alertId} {
      allow read, write: if isAuthenticated() && (request.resource.data.companyId == getUserData().companyId || resource.data.companyId == getUserData().companyId || isSuperAdmin());
    }
  }
}
